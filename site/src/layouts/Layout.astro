---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Frontier Signals",
  description = "A publishing system for recurring research and synthesized updates."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #f4efe7;
    --surface: rgba(255, 252, 246, 0.82);
    --surface-strong: #fffaf2;
    --text: #1f1d1a;
    --muted: #625b52;
    --line: rgba(69, 53, 36, 0.14);
    --accent: #0d7c66;
    --accent-strong: #074c43;
    --warm: #d97706;
    --shadow: 0 24px 60px rgba(61, 45, 30, 0.14);
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: Georgia, "Times New Roman", serif;
    background:
      radial-gradient(circle at top left, rgba(217, 119, 6, 0.16), transparent 30%),
      radial-gradient(circle at right 20%, rgba(13, 124, 102, 0.2), transparent 28%),
      linear-gradient(180deg, #f8f4ed 0%, var(--bg) 100%);
    color: var(--text);
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  a {
    color: inherit;
  }
}</style>
