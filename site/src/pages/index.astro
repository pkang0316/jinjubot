---
import { readFileSync } from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import TopicPulse from '../components/TopicPulse';
import Layout from '../layouts/Layout.astro';

type Topic = {
  name: string;
  signal: number;
  change: string;
  note: string;
};

type Digest = {
  siteTitle: string;
  tagline: string;
  updatedAt: string;
  cadence: string;
  summary: string;
  topics: Topic[];
  highlights: string[];
};

const pageDir = path.dirname(fileURLToPath(import.meta.url));
const contentPath = path.resolve(pageDir, '../../../content/research-digest.json');
const digest = JSON.parse(readFileSync(contentPath, 'utf8')) as Digest;
const updatedLabel = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'long',
  timeStyle: 'short'
}).format(new Date(digest.updatedAt));
---

<Layout title={digest.siteTitle} description={digest.summary}>
  <main class="shell">
    <section class="hero panel">
      <div class="hero__copy">
        <p class="eyebrow">Agentic research publishing starter</p>
        <h1>{digest.siteTitle}</h1>
        <p class="lede">{digest.tagline}</p>
        <p class="summary">{digest.summary}</p>
      </div>
      <dl class="hero__meta">
        <div>
          <dt>Cadence</dt>
          <dd>{digest.cadence}</dd>
        </div>
        <div>
          <dt>Last update</dt>
          <dd>{updatedLabel}</dd>
        </div>
        <div>
          <dt>Content source</dt>
          <dd><code>content/research-digest.json</code></dd>
        </div>
      </dl>
    </section>

    <section class="content-grid">
      <article class="panel">
        <div class="section-heading">
          <p class="eyebrow">Signal board</p>
          <h2>Topics worth watching</h2>
        </div>
        <TopicPulse client:load topics={digest.topics} />
      </article>

      <article class="panel">
        <div class="section-heading">
          <p class="eyebrow">Publishing loop</p>
          <h2>How this repo is wired</h2>
        </div>
        <ol class="steps">
          <li>Run a research job on a daily or weekly schedule.</li>
          <li>Write normalized content into the repo.</li>
          <li>Build static HTML with Astro.</li>
          <li>Deploy via CI while Terraform manages infrastructure.</li>
        </ol>
      </article>
    </section>

    <section class="panel highlights">
      <div class="section-heading">
        <p class="eyebrow">Starter notes</p>
        <h2>Current highlights</h2>
      </div>
      <ul>
        {digest.highlights.map((highlight) => <li>{highlight}</li>)}
      </ul>
    </section>
  </main>
</Layout>

<style>
  .shell {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 40px 0 72px;
  }

  .panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 28px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(12px);
  }

  .hero {
    padding: 32px;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
    margin-bottom: 24px;
  }

  .eyebrow {
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-family: Arial, sans-serif;
    font-size: 0.72rem;
    color: var(--accent-strong);
  }

  h1,
  h2,
  h3,
  p,
  li,
  dt,
  dd {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 16px;
    font-size: clamp(3rem, 8vw, 5.4rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  h2 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    line-height: 1;
    margin-bottom: 0;
  }

  .lede {
    max-width: 48rem;
    font-size: 1.3rem;
    color: var(--muted);
  }

  .summary {
    max-width: 42rem;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .hero__meta {
    display: grid;
    gap: 16px;
    align-content: start;
    padding: 20px;
    background: var(--surface-strong);
    border-radius: 22px;
    border: 1px solid var(--line);
  }

  .hero__meta dt {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    font-family: Arial, sans-serif;
    margin-bottom: 4px;
  }

  .hero__meta dd {
    margin-left: 0;
    font-size: 1rem;
  }

  .content-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1.6fr) minmax(280px, 1fr);
    margin-bottom: 24px;
  }

  .content-grid > .panel,
  .highlights {
    padding: 28px;
  }

  .section-heading {
    margin-bottom: 20px;
  }

  .steps {
    margin: 0;
    padding-left: 20px;
    line-height: 1.8;
  }

  .steps li + li {
    margin-top: 10px;
  }

  .highlights ul {
    margin: 0;
    padding-left: 20px;
    line-height: 1.8;
  }

  .highlights li + li {
    margin-top: 10px;
  }

  code {
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: rgba(13, 124, 102, 0.1);
    font-family: "Courier New", monospace;
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .hero,
    .content-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .shell {
      width: min(100% - 20px, 1120px);
      padding-top: 20px;
    }

    .hero,
    .content-grid > .panel,
    .highlights {
      padding: 22px;
    }
  }
</style>
